# AI Knowledge Assistant — Environment Configuration
# ─────────────────────────────────────────────────
# Copy this file to `.env` and fill in your values.
# The .env file is gitignored — never commit secrets.

# ── LLM Backend ──────────────────────────────────
# Choose: "openai" or "huggingface"
LLM_BACKEND=openai

# OpenAI settings (required when LLM_BACKEND=openai)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-3.5-turbo

# HuggingFace settings (optional, used when LLM_BACKEND=huggingface)
HF_API_TOKEN=hf_your_huggingface_api_token_here
HF_MODEL_NAME=HuggingFaceH4/zephyr-7b-beta

# ── Endee Vector Database ─────────────────────────
# Default: local Docker instance on port 8080
# Change only if running Endee on a different host/port
ENDEE_HOST=http://localhost:8080
